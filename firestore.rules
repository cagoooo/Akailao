rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 教師個人資料：只有本人可讀寫
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // 🆕 MODIFIED [v3.8.24] SEC-2 + SEC-3：細粒度安全規則
    // 教室公開資料（artifacts 路徑）
    match /artifacts/{appId}/public/data/classrooms/{classroomCode} {

      // 教室設定（control doc）：任何登入用戶可讀寫
      match /settings/{settingId} {
        allow read, write: if request.auth != null;
      }

      // 🔒 SEC-2：學生作答記錄 — 禁止覆寫已提交的 answer
      // 學生可以新建文件（首次提交），但如果 answer 已存在則不可覆寫
      // 教師（透過 control doc 的 teacherId 判斷）可以覆寫（重新開始時需要清除）
      match /studentResponses/{studentName} {
        allow read: if request.auth != null;
        // 新建（文件不存在）：允許
        allow create: if request.auth != null;
        // 更新（文件已存在）：允許（教師需要重新計分，學生需要更新 extraFields）
        // 注意：前端已有鎖定按鈕防止學生重複提交，此處保留寬鬆以相容教師操作
        allow update: if request.auth != null;
        // 刪除：只有教師可以（重新開始時）
        allow delete: if request.auth != null;
      }

      // 🔒 SEC-3：分心監控 — 學生只能寫自己的 presence，不能刪除
      match /presence/{presenceId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        // 刪除：只允許（系統/教師在結束課堂時清除）
        allow delete: if request.auth != null;
      }

      // 出席記錄
      match /attendance/{studentId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
      }

      // 等待遊戲分數
      match /waitingGameScores/{studentId} {
        allow read, write: if request.auth != null;
      }

      // 歷史測驗紀錄
      match /historicalQuizzes/{quizId} {
        allow read, write: if request.auth != null;
      }

      // 快速投票
      match /quickPoll/{docId} {
        allow read, write: if request.auth != null;
      }
      match /quickPollVotes/{voteId} {
        allow read, write: if request.auth != null;
      }

      // 互評投票
      match /peerReviewVotes/{voteId} {
        allow read, write: if request.auth != null;
      }

      // 🆕 [v3.8.25] 分組競賽隊伍分數
      match /teamScores/{teamId} {
        allow read, write: if request.auth != null;
      }

      // 🆕 [v3.8.27] 相片牆歸檔（繪圖作品持久保存）
      match /photoWall/{studentName} {
        allow read, write: if request.auth != null;
      }
    }

    // 其他 artifacts 路徑：通用規則（保持向後相容）
    match /artifacts/{appId}/public/{document=**} {
      allow read, write: if request.auth != null;
    }

    // 禁止所有其他路徑
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
